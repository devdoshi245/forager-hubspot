# Forager API credentials
FORAGER_API_KEY=your_forager_api_key_here
FORAGER_ACCOUNT_ID=your_forager_account_id_here

# HubSpot Private App token
HUBSPOT_TOKEN=your_hubspot_private_app_token_here

# --- Endpoint auth (shared secret) ------------------------------------------
# Protects the webhook + /enrich/* + /debug/* endpoints (they spend Forager
# credits and write to the CRM). Send it as header "X-App-Secret: <secret>" or
# query "?token=<secret>". Point HubSpot's webhook Target URL at
# https://<app>.up.railway.app/webhook?token=<secret>. If unset, the endpoints
# stay OPEN (with a loud log warning) — SET THIS BEFORE GOING LIVE.
APP_SECRET=generate_a_long_random_string_here

# --- Company scoring (ICP fit + logo recognizability) -----------------------
# Pluggable LLM provider. If no key is set, enrichment still runs and the two
# score sets are simply skipped. Web search / LLM usage is billed to the LLM
# account, NOT Forager credits.
#
# Provider selection: defaults to whichever key is present (Gemini wins if both).
# Force it explicitly with SCORING_PROVIDER = gemini | anthropic.
# SCORING_PROVIDER=gemini

# Google Gemini (free tier; logo step uses Google Search grounding) — testing.
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: defaults to gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic / Claude — for the client (swap to this later, no code change).
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: defaults to claude-opus-4-8
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Error email alerts (optional) -------------------------------------------
# When the pipeline hits a real failure, email the reason + traceback. Stays OFF
# until SMTP_* and ALERT_EMAIL_TO are set. Works with any SMTP provider.
# Example below is Gmail (use a Google "App Password", not your login password).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your_smtp_app_password
# SMTP_USE_TLS=true
# ALERT_EMAIL_FROM=you@gmail.com
# ALERT_EMAIL_TO defaults to doshidev58@gmail.com if omitted; set to override.
# ALERT_EMAIL_TO=someone@example.com,another@example.com

# --- Deepline (Workflow 3: work email + phone) + company Funding --------------
# OPTIONAL and DORMANT until set: without DEEPLINE_API_KEY, none of the Deepline
# code runs and the service behaves exactly as before. Per-provider keys (ContactOut,
# Prospeo, Hunter, LeadMagic, PDL, Icypeas, Crustdata, ZeroBounce, Lusha, FullEnrich)
# are BYOK and configured in the Deepline dashboard — NOT here.
# DEEPLINE_API_KEY=dlp_xxx
#
# Work-email order (single chain). Comma-separated tool keys; finalized with the client.
# DEEPLINE_EMAIL_ORDER=hunter,leadmagic,prospeo,contactout,pdl,crustdata,lusha
#
# Only accept a work email whose domain matches the contact's company domain (guards
# against enrich tools returning the person's email at a DIFFERENT employer). Default ON.
# Set to "off" for companies whose email domain differs from their website domain.
# DEEPLINE_EMAIL_DOMAIN_MATCH=on
#
# Phone order is PER REGION (the contact's country picks the region). Defaults below
# match Shirish's email (client list still pending final sign-off). Override per region:
# DEEPLINE_PHONE_ORDER_NAMER=upcell,pdl,findymail,wiza,prospeo
# DEEPLINE_PHONE_ORDER_EUROPE=prospeo,wiza,datagma,pdl,contactout
# DEEPLINE_PHONE_ORDER_MEA=pdl,wiza,prospeo,datagma,contactout
# DEEPLINE_PHONE_ORDER_APAC=pdl,wiza,prospeo,leadmagic,findymail
# DEEPLINE_PHONE_ORDER_LATAM=pdl,wiza,datagma,prospeo,findymail
#
# Phone validation: NAMER-only Trestle Real-Contact name-match. Set to "off" to skip
# phone validation entirely (e.g. if Real Contact proves tricky in Deepline).
# DEEPLINE_PHONE_VALIDATION=on
#
# Company funding source (per client: Crustdata).
# DEEPLINE_FUNDING_TOOL=crustdata_company_enrichment
#
# --- Tier 1/2 classification (NOT Deepline-gated — runs after Claude scoring) -------
# HubSpot field to write "Tier 1"/"Tier 2" into. Pending the client's confirmation of
# the exact field ("Tier" vs "Source"); default below.
# TIER_FIELD=tier
